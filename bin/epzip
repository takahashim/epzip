#!/usr/bin/env ruby

require 'epzip'

def error_and_exit(msg)
  STDERR.puts msg
  exit
end

def usage()
    error_and_exit "usage: epzip <srcdir> [filename]"
end

if !(ARGV.size == 1 or ARGV.size == 2)
   usage
end

dir = ARGV.shift
if !File.exist? dir
  error_and_exit "No such directory: #{dir}"
end

file = ARGV.shift
if file and File.exist? file
  error_and_exit "File already exists: #{file}"
end

Epzip.zip(dir, file)
